# Personal Claude Code config (permissions) — not shared. This pattern ignores the file both
# in this standalone project and while the folder is still nested inside its origin repo.
.claude/settings.local.json

# The shared engine pin (.claude/settings.json) is intentionally NOT ignored — it travels with
# the repo so every clone runs on the same model/effort.

# cycle runtime
/.factory/
/cycle.log
PAUSE

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/

# Web UI (ADR 0022) — node deps and the build artifact are prerequisites, not committed
node_modules/
/web/dist/

# Server runtime artifacts (default paths from build_app when run locally)
/radio-server.jsonl
/recordings/

# Local config (ADR 0025). radio.toml.example IS committed (the documented template); a real
# radio.toml and especially radio-secrets.toml (holds the TOTP/API secrets) must never be.
/radio.toml
/radio-secrets.toml

# Operator-authored service plugins (ADR 0051) — this deployment's own, never the repo's
/local_services/

# Local piper voice models (large binaries; download per machine)
voices/
